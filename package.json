{
    "name": "codexboard",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "packageManager": "bun@1.3.9",
    "engines": {
        "bun": ">=1.3.9"
    },
    "scripts": {
        "dev": "bun run dev:server & vite",
        "dev:server": "bun --watch server.mjs",
        "build": "vite build",
        "preview": "vite preview",
        "serve": "bun server.mjs",
        "lint": "bunx eslint .",
        "lint:fix": "bunx eslint . --fix",
        "format": "bunx prettier . --write",
        "format:check": "bunx prettier . --check",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "check": "bun run typecheck && bun run lint && bun run format:check && bun run build",
        "feed:sample": "curl -X POST http://localhost:8787/api/cache/sample"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.90.10",
        "lucide-react": "^0.554.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.1.0",
        "complete-lint": "^5.1.5",
        "eslint": "^9.39.1",
        "eslint-config-complete": "^4.1.4",
        "prettier": "^3.6.2",
        "typescript": "^5.9.3",
        "vite": "^7.1.12"
    }
}
